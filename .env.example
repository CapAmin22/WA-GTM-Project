# ============================================
# WA GTM Project — Environment Variables
# ============================================
# Copy this file to .env (worker) or .env.local (dashboard) and fill in values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Worker-only: Service Role Key (bypasses RLS — NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Worker-only: Logging
LOG_LEVEL=info
NODE_ENV=development
