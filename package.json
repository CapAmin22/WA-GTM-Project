{
  "name": "wa-gtm-project",
  "version": "1.0.0",
  "private": true,
  "description": "WhatsApp Go-To-Market Engine — Dynamic Account Scaling",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
